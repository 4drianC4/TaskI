generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Accounts {
  id                  String  @id
  user_id             String
  type                String
  provider            String
  provider_account_id String
  refresh_token       String?
  access_token        String?
  expires_at          Int?
  token_type          String?
  scope               String?
  Users               Users   @relation(fields: [user_id], references: [id])
}

model ActivityLogs {
  id         String   @id
  task_id    String
  user_id    String
  action     String
  created_at DateTime @default(now())
  Tasks      Tasks    @relation(fields: [task_id], references: [id])
  Users      Users    @relation(fields: [user_id], references: [id])
}

model Boards {
  id           String           @id @default(cuid())
  workspace_id String
  name         String
  cover_color  String?
  cover_image  String?
  state        BoardState?
  visibility   BoardVisibility?
  created_at   DateTime         @default(now())
  updated_at   DateTime?        @updatedAt
  deleted_at   DateTime?
  Workspaces   Workspaces       @relation(fields: [workspace_id], references: [id])
  Columns      Columns[]
}

model Columns {
  id         String    @id
  board_id   String
  name       String
  order      Int
  is_done    Boolean   @default(false)
  created_at DateTime  @default(now())
  deleted_at DateTime?
  Boards     Boards    @relation(fields: [board_id], references: [id])
  Tasks      Tasks[]
}

model Comments {
  id         String    @id
  task_id    String
  user_id    String
  content    String
  created_at DateTime  @default(now())
  updated_at DateTime?
  deleted_at DateTime?
  Tasks      Tasks     @relation(fields: [task_id], references: [id])
  Users      Users     @relation(fields: [user_id], references: [id])
}

model Permissions {
  id              String            @id
  action          String            @unique
  level           String
  description     String?
  RolePermissions RolePermissions[]
}

model RolePermissions {
  role_id       String
  permission_id String
  level         RoleLevel
  Permissions   Permissions @relation(fields: [permission_id], references: [id])
  Roles         Roles       @relation(fields: [role_id], references: [id])

  @@id([role_id, permission_id])
}

model Roles {
  id               String             @id
  name             String             @unique
  level            RoleLevel
  description      String?
  RolePermissions  RolePermissions[]
  Users            Users[]
  WorkspaceMembers WorkspaceMembers[]
}

model Sessions {
  id            String   @id
  session_token String   @unique
  user_id       String
  expires       DateTime
  Users         Users    @relation(fields: [user_id], references: [id])
}

model Subtasks {
  id           String    @id
  task_id      String
  title        String
  order        Int
  is_completed Boolean   @default(false)
  created_at   DateTime  @default(now())
  deleted_at   DateTime?
  Tasks        Tasks     @relation(fields: [task_id], references: [id])
}

model Tags {
  id           String     @id
  workspace_id String
  name         String
  color        String
  deleted_at   DateTime?
  Workspaces   Workspaces @relation(fields: [workspace_id], references: [id])
  TaskTags     TaskTags[]
}

model TaskTags {
  task_id String
  tag_id  String
  Tags    Tags   @relation(fields: [tag_id], references: [id])
  Tasks   Tasks  @relation(fields: [task_id], references: [id])

  @@id([task_id, tag_id])
}

model Tasks {
  id           String         @id
  column_id    String
  assignee_id  String?
  title        String
  description  String?
  order        Int
  due_date     DateTime?
  created_at   DateTime       @default(now())
  updated_at   DateTime?
  deleted_at   DateTime?
  ActivityLogs ActivityLogs[]
  Comments     Comments[]
  Subtasks     Subtasks[]
  TaskTags     TaskTags[]
  Users        Users?         @relation(fields: [assignee_id], references: [id])
  Columns      Columns        @relation(fields: [column_id], references: [id])
}

model Users {
  id               String             @id
  name             String?
  email            String             @unique
  email_verified   DateTime?
  image            String?
  bio              String?
  system_role_id   String
  created_at       DateTime           @default(now())
  updated_at       DateTime?
  deleted_at       DateTime?
  Accounts         Accounts[]
  ActivityLogs     ActivityLogs[]
  Comments         Comments[]
  Sessions         Sessions[]
  Tasks            Tasks[]
  Roles            Roles              @relation(fields: [system_role_id], references: [id])
  WorkspaceMembers WorkspaceMembers[]
  Workspaces       Workspaces[]
}

model WorkspaceMembers {
  id           String     @id
  workspace_id String
  user_id      String
  role_id      String
  joined_at    DateTime   @default(now())
  Roles        Roles      @relation(fields: [role_id], references: [id])
  Users        Users      @relation(fields: [user_id], references: [id])
  Workspaces   Workspaces @relation(fields: [workspace_id], references: [id])

  @@unique([workspace_id, user_id])
}

model Workspaces {
  id               String             @id
  name             String
  description      String?
  owner_id         String
  created_at       DateTime           @default(now())
  updated_at       DateTime?
  deleted_at       DateTime?
  Boards           Boards[]
  Tags             Tags[]
  WorkspaceMembers WorkspaceMembers[]
  Users            Users              @relation(fields: [owner_id], references: [id])
}

enum BoardState {
  active
  inactive
  finished
}

enum BoardVisibility {
  private
  workspace
  public
}

enum RoleLevel {
  system
  workspace
}
